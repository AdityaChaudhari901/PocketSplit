# Mobile-safe public values. The anon key is protected by Supabase RLS policies.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_ENABLE_DEMO_MODE=true
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Android Expo Go cannot load expo-notifications on SDK 53. Keep false unless testing Android reminders in a development build.
EXPO_PUBLIC_ENABLE_ANDROID_NOTIFICATIONS_IN_DEV=false

# Supabase Edge Function secrets. Never expose these to the mobile app.
APP_ENV=development
AI_REQUIRE_AUTH=false
AI_ALLOW_MOCKS=true
AI_PROVIDER=bedrock
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Optional fallback if you prefer IAM access keys over a Bedrock bearer token.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional provider and payments wiring.
OCR_PROVIDER=mock
REVENUECAT_API_KEY=
